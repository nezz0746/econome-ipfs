# ---------------------------------------------------------------------------
# Production env for Dokploy → Environment Settings (paste, then fill the <…>).
# Used by docker-compose.prod.yml. See DEPLOYMENT.md.
#
# Generate the secrets locally:
#   openssl rand -hex 32   # CLUSTER_SECRET, BETTER_AUTH_SECRET, ENCRYPTION_KEY
#   openssl rand -hex 24   # INTERNAL_TOKEN
#   openssl rand -hex 16   # POSTGRES_PASSWORD
#
# NOTE: Dokploy does NOT interpolate one variable into another, so write the
# literal password into DATABASE_URL (don't use ${POSTGRES_PASSWORD} there).
# ---------------------------------------------------------------------------

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<db-password>
POSTGRES_DB=econome
# host is the compose service name "postgres"; password must match above:
DATABASE_URL=postgres://postgres:<db-password>@postgres:5432/econome

# ---- IPFS Cluster ----
# 32-byte hex shared by all cluster peers; share only with vetted participants.
CLUSTER_SECRET=<cluster-secret>
# Production: set to the main peer ID(s) instead of "*" so followers are
# read-only. Find the ID on the Peers page or in the cluster container logs.
CLUSTER_TRUSTED_PEERS=*

# ---- Hono API ----
# Shared secret between the Next dashboard (BFF) and the API.
INTERNAL_TOKEN=<internal-token>
REPLICATION_MIN=-1
REPLICATION_MAX=-1
ACCOUNTING_INTERVAL_MS=60000

# ---- Next dashboard ----
# Must exactly equal the public dashboard URL (the domain you attach to `web`).
BETTER_AUTH_URL=https://<your-dashboard-domain>
BETTER_AUTH_SECRET=<auth-secret>
# Encrypts API keys at rest. WARNING: changing this makes existing stored keys
# unreadable (they must be rotated). Keep it stable.
ENCRYPTION_KEY=<encryption-key>
# Public IPFS gateway for the "open" links on the Files page.
IPFS_GATEWAY_URL=https://<your-gateway-domain>
CLUSTER_NAME=econome
# Public multiaddr participants bootstrap against. Fill in after the first
# deploy once you know the main peer ID, then redeploy:
#   /dns4/<your-host>/tcp/9096/p2p/<MAIN_PEER_ID>
CLUSTER_BOOTSTRAP=
