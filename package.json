{
  "name": "econome-ipfs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:migrate": "pnpm --filter @repo/db db:migrate",
    "infra:up": "docker compose up -d --wait postgres kubo cluster",
    "infra:down": "docker compose down",
    "compose:full": "docker compose --profile apps up --build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@leconome/payload-storage-ipfs && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.27.10",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "0.25.12"
    }
  }
}
