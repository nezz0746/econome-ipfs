# Copy to .env and fill in. docker-compose reads this file automatically.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=econome
DATABASE_URL=postgres://postgres:postgres@postgres:5432/econome

# ---- IPFS Cluster ----
# 32-byte hex secret shared by all cluster peers. Generate:
#   openssl rand -hex 32
CLUSTER_SECRET=replace-with-openssl-rand-hex-32
# Trust model: "*" trusts all peers (dev only). In prod set to the main peer ID.
CLUSTER_TRUSTED_PEERS=*

# ---- Hono API ----
PORT=8080
CLUSTER_API_URL=http://cluster:9094
# Shared secret between the Next BFF and the API. Generate:
#   openssl rand -hex 24
INTERNAL_TOKEN=replace-with-internal-token
# Replication factors for pins (-1 = pin everywhere / use cluster default).
REPLICATION_MIN=-1
REPLICATION_MAX=-1
# Accounting snapshot interval in ms (omit/empty to disable).
ACCOUNTING_INTERVAL_MS=60000

# ---- Next dashboard ----
HONO_URL=http://api:8080
# Better Auth — generate a secret: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-auth-secret
BETTER_AUTH_URL=http://localhost:3000
# Encrypts API keys at rest so they can be revealed/copied in the dashboard.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-encryption-key
# Public IPFS gateway used for the "open" links on the Files page.
IPFS_GATEWAY_URL=http://localhost:8081
# Onboarding bundle values shown to participants.
CLUSTER_NAME=econome
# Public multiaddr participants bootstrap against (the main cluster peer).
CLUSTER_BOOTSTRAP=

# ---- Local follower emulation (profile: follower) ----
# After first `docker compose up`, copy the main cluster peer ID from its logs
# (or the dashboard) and set the bootstrap multiaddr so the follower can join:
#   /dns4/cluster/tcp/9096/p2p/<MAIN_PEER_ID>
CLUSTER_MAIN_PEER_MULTIADDR=
